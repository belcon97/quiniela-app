generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum MatchStatus {
  pending
  completed
}

enum Role {
  user
  admin
}

model User {
  id          String       @id @default(uuid())
  name        String
  username    String       @unique
  email       String       @unique
  password    String
  role        Role         @default(user)
  usedWildcard Boolean @default(false)
  
  createdAt   DateTime     @default(now())
  predictions Prediction[]
  topScorerPrediction UserTopScorerPrediction?
}

model Match {
  id          String      @id @default(uuid())
  homeTeam    String
  awayTeam    String
  homeFlag    String
  awayFlag    String
  group       String
  stadium     String
  date        DateTime
  homeScore   Int?
  awayScore   Int?
  status      MatchStatus @default(pending)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  predictions Prediction[]
}

model Prediction {
  id        String   @id @default(uuid())
  userId    String
  matchId   String
  homeScore Int
  awayScore Int
  points    Int?
  isWildcard Boolean @default(false)
  penaltyWinner String? // "home" | "away" | null
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
}

model TopScorer {
  id        String   @id @default(uuid())
  name      String
  team      String
  flag      String
  goals     Int      @default(0)
  isWinner  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  predictions UserTopScorerPrediction[]
}

model UserTopScorerPrediction {
  id          String     @id @default(uuid())
  userId      String     @unique
  topScorerId String?
  customName  String?
  points      Int        @default(0)
  createdAt   DateTime   @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  topScorer TopScorer? @relation(fields: [topScorerId], references: [id])
}