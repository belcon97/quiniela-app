generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  user
  admin
}

enum MatchStatus {
  pending
  completed
}

enum PenaltyWinner {
  home
  away
}

model User {
  id          String       @id @default(uuid())
  name        String
  username    String       @unique
  password    String?
  
  favoriteTeam  String?
  hasReadRules  Boolean  @default(false)

  role        Role         @default(user)
  
  createdAt   DateTime     @default(now())
  predictions Prediction[]
  topScorerPrediction UserTopScorerPrediction?
}

model Match {
  id          String      @id @default(uuid())
  homeTeam    String
  awayTeam    String
  homeFlag    String
  awayFlag    String

  group       String

  date        DateTime

  homeScore   Int?
  awayScore   Int?

  status      MatchStatus @default(pending)

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  predictions Prediction[]
}

model Prediction {
  id        String   @id @default(uuid())
  userId    String
  matchId   String
  homeScore Int
  awayScore Int
  points    Int?

  isWildcard Boolean @default(false)
  penaltyWinner PenaltyWinner?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, matchId])
}

model TopScorer {
  id        String   @id @default(uuid())
  isActive Boolean @default(true)
  name      String @unique
  team      String
  flag      String
  goals     Int      @default(0)

  isWinner  Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  predictions UserTopScorerPrediction[]
}

model UserTopScorerPrediction {
  id          String    @id @default(uuid())
  userId      String    @unique
  topScorerId String    // ← deja de ser opcional
  points      Int       @default(0)
  createdAt   DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  topScorer TopScorer @relation(fields: [topScorerId], references: [id])
}